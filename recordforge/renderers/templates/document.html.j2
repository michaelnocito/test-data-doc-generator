<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ data.doc_type | replace('_', ' ') | title }} — RecordForge</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 900px;
      margin: 40px auto;
      padding: 0 20px;
      line-height: 1.5;
      color: #222;
    }
    body::before {
      content: "SAMPLE";
      position: fixed;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%) rotate(-45deg);
      font-size: 8rem; font-weight: 900;
      color: rgba(255, 0, 0, 0.08);
      pointer-events: none; z-index: 9999;
    }
    h1 { font-size: 1.8rem; margin-bottom: 4px; }
    .meta { color: #555; font-size: 0.9rem; margin-bottom: 20px; }
    hr { border: none; border-top: 1px solid #ddd; margin: 20px 0; }
    .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
    .party h3 { margin: 0 0 6px; font-size: 0.85rem; text-transform: uppercase; color: #777; }
    .party p { margin: 2px 0; font-size: 0.9rem; }
    table { width: 100%; border-collapse: collapse; margin-top: 24px; }
    th { background: #f0f0f0; font-weight: bold; padding: 8px 10px; text-align: left; border-bottom: 2px solid #ccc; }
    td { padding: 7px 10px; border-bottom: 1px solid #eee; font-size: 0.9rem; }
    tr:nth-child(even) td { background: #fafafa; }
    .num { text-align: right; }
    .totals { margin-top: 12px; text-align: right; font-size: 0.9rem; }
    .totals .total-due { font-weight: bold; font-size: 1rem; }
    .notes { margin-top: 24px; font-size: 0.9rem; white-space: pre-wrap; }
    .footer {
      margin-top: 40px;
      font-size: 0.7rem;
      color: #aaa;
      text-align: center;
      font-style: italic;
    }
    .notice {
      background: #fff3cd;
      border: 1px solid #f0d98a;
      padding: 10px 14px;
      border-radius: 6px;
      margin-bottom: 20px;
      font-size: 0.8rem;
    }
  </style>
</head>
<body>
  <div class="notice">FICTIONAL — For testing, demo, and training use only. Not a valid legal or financial document.</div>

  <h1>{{ data.doc_type | replace('_', ' ') | title }}</h1>
  <div class="meta">
    {{ data.doc_number }}
    {% if data.doc_date %} &nbsp;·&nbsp; {{ data.doc_date }}{% endif %}
    {% if data.due_date %} &nbsp;·&nbsp; Due: {{ data.due_date }}{% endif %}
  </div>
  <hr>

  <div class="parties">
    <div class="party">
      <h3>Bill To</h3>
      <p><strong>{{ data.buyer.name }}</strong></p>
      <p>{{ data.buyer.address1 }}</p>
      <p>{{ data.buyer.address2 }}</p>
      <p>{{ data.buyer.phone }}</p>
      <p>{{ data.buyer.email }}</p>
    </div>
    <div class="party">
      <h3>From</h3>
      <p><strong>{{ data.vendor.name }}</strong></p>
      <p>{{ data.vendor.address1 }}</p>
      <p>{{ data.vendor.address2 }}</p>
      <p>{{ data.vendor.phone }}</p>
      <p>{{ data.vendor.email }}</p>
    </div>
  </div>

  {% if data.line_items %}
  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th class="num">Qty</th>
        <th class="num">Unit Price</th>
        <th class="num">Total</th>
      </tr>
    </thead>
    <tbody>
      {% for item in data.line_items %}
      <tr>
        <td>{{ item.description }}</td>
        <td class="num">{{ item.quantity }}</td>
        <td class="num">${{ "%.2f"|format(item.unit_price) }}</td>
        <td class="num">${{ "%.2f"|format(item.total) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <div class="totals">
    <div>Subtotal: ${{ "%.2f"|format(data.subtotal) }}</div>
    <div>Tax (8%): ${{ "%.2f"|format(data.tax) }}</div>
    <div class="total-due">Total Due: ${{ "%.2f"|format(data.total_due) }}</div>
  </div>
  {% endif %}

  {% if data.notes %}
  <div class="notes">{{ data.notes }}</div>
  {% endif %}

  <div class="footer">FICTIONAL — For testing, demo, and training use only. Not a valid legal or financial document.</div>
</body>
</html>
